# Copy to .env for local development: cp .env.example .env
# In production these are set in the host's env-var UI (see render.yaml), never
# committed. .env itself is gitignored.

# ---- runtime ----
NODE_ENV=development

# ---- api ----
# NOTE: authentication is DISABLED in this build — no login, JWT or RBAC. Every
# endpoint is public and the dashboard loads directly. Put an identity proxy
# (e.g. Cloudflare Access) in front of both the web and api services before
# exposing them to the internet.
API_PORT=4000

# ---- database ----
# Local docker-compose Postgres.
DATABASE_URL=postgres://seo_guardian:seo_guardian@localhost:5432/seo_guardian
# Production only: the DIRECT/unpooled URL. Migrations take advisory locks and
# run DDL, which a transaction-mode pooler (PgBouncer, Neon's -pooler host)
# breaks. Leave empty locally.
DIRECT_DATABASE_URL=

# ---- redis / queues ----
# Must be configured with maxmemory-policy=noeviction. BullMQ keeps job state in
# ordinary keys; any LRU policy drops them and crawls hang mid-run.
REDIS_URL=redis://localhost:6379

# ---- object storage (MinIO locally, S3/R2 in prod) ----
# Leave S3_ACCESS_KEY empty to disable raw-HTML archival. Page artifacts still
# persist in Postgres, so this is safe to skip.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_UPLOADS=seo-guardian-uploads
S3_BUCKET_HTML=seo-guardian-html
S3_FORCE_PATH_STYLE=true

# ---- worker / crawler ----
# Queues this worker consumes; '*' = all. Split pools e.g. WORKER_QUEUES=page-render
WORKER_QUEUES=*
# Identify the crawler and give site owners a way to reach you.
CRAWLER_USER_AGENT=SEOGuardianBot/0.1 (+https://example.com/bot)
FETCH_CONCURRENCY=8
# Each concurrent Chromium context costs a few hundred MB — keep this at 1 on a
# 2GB instance.
RENDER_CONCURRENCY=2
LINK_CHECK_CONCURRENCY=6
DEFAULT_DOMAIN_RATE_PER_SEC=5
DEFAULT_DOMAIN_CONCURRENCY=4
# SSRF-guard bypass for specific host:port fixtures (tests only). MUST be empty
# in production — with an unauthenticated API this is especially dangerous.
CRAWLER_ALLOW_PRIVATE_TARGETS=

# ---- web ----
# Compiled into the client bundle at BUILD time — a runtime env var cannot
# change it. In production this is the ARG default in docker/web.Dockerfile.
NEXT_PUBLIC_API_URL=http://localhost:4000
