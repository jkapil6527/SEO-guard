{
  "name": "seo-guardian",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "bash scripts/start.sh",
    "stop": "docker compose down",
    "clean": "rm -rf apps/*/.next apps/*/dist packages/*/dist **/.turbo .turbo",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:int": "turbo run test:int",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "pnpm --filter @seo-guardian/db migrate:up",
    "db:migrate:down": "pnpm --filter @seo-guardian/db migrate:down",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@eslint/js": "^9.28.0",
    "@commitlint/config-conventional": "^19.8.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.0"
  }
}
