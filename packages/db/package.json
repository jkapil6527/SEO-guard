{
  "name": "@seo-guardian/db",
  "version": "0.1.0",
  "private": true,
  "description": "Migrations, connection pool and repositories. All SQL lives here.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "true",
    "migrate:up": "node-pg-migrate up -m migrations --migration-filename-format utc",
    "migrate:down": "node-pg-migrate down -m migrations"
  },
  "dependencies": {
    "@seo-guardian/shared": "workspace:*",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@seo-guardian/config": "workspace:*",
    "@types/pg": "^8.15.2",
    "node-pg-migrate": "^7.9.1"
  }
}
